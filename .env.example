# GramCredit environment template (free-tier friendly)
# Copy to .env.local and fill required keys.

# ==============================
# Core AI APIs
# ==============================
# Free tier available: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional paid fallback for STT only if you want OpenAI Whisper.
OPENAI_API_KEY=

# STT provider selection (groq | openai)
GRAMCREDIT_STT_PROVIDER=groq
GRAMCREDIT_STT_MODEL=whisper-large-v3-turbo

# ==============================
# Satellite provider
# ==============================
# Use mock by default for hackathon reliability (no key required)
GRAMCREDIT_SATELLITE_PROVIDER=mock

# Optional providers if you integrate real satellite APIs later
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
BHUVAN_API_KEY=

# ==============================
# Social graph + GNN
# ==============================
# true enables in-app message-passing GNN trust scoring
GRAMCREDIT_SOCIAL_USE_GNN_MODEL=true
GRAMCREDIT_GNN_MODEL_PATH=/models/gnn-trust-model.json
GRAMCREDIT_TX_THRESHOLD_DAYS=90
GRAMCREDIT_MIN_CLUSTER_SIZE=3
GRAMCREDIT_TRUST_NORMALIZATION=minmax

# ==============================
# Voice engine
# ==============================
GRAMCREDIT_VOICE_MODEL_ID=whisper-large-v3-turbo
GRAMCREDIT_GROQ_MODEL=llama-3.3-70b-versatile
GRAMCREDIT_VOICE_CONFIDENCE=0.7
GRAMCREDIT_INTERVIEW_LANGUAGE=en
GRAMCREDIT_MAX_AUDIO_DURATION=600

# ==============================
# Satellite thresholds
# ==============================
GRAMCREDIT_NDVI_HEALTHY=0.5
GRAMCREDIT_NDVI_STRUGGLING=0.3
GRAMCREDIT_NDVI_CRITICAL=0.1
GRAMCREDIT_ANOMALY_SENSITIVITY=2.5
GRAMCREDIT_IMAGE_SEARCH_DAYS=30

# ==============================
# Behavior engine
# ==============================
GRAMCREDIT_CONSISTENCY_WINDOW=90
GRAMCREDIT_MIN_TRANSACTIONS=10
GRAMCREDIT_RECHARGE_WEIGHT=0.4
GRAMCREDIT_TX_FREQUENCY_WEIGHT=0.6
GRAMCREDIT_BEHAVIOR_ANOMALY_THRESHOLD=3

# ==============================
# Fusion weights (must sum to 1.0)
# ==============================
GRAMCREDIT_WEIGHT_VOICE=0.25
GRAMCREDIT_WEIGHT_SOCIAL=0.30
GRAMCREDIT_WEIGHT_SATELLITE=0.30
GRAMCREDIT_WEIGHT_BEHAVIOR=0.15
GRAMCREDIT_NORMALIZATION=minmax

# ==============================
# Decision thresholds
# ==============================
GRAMCREDIT_THRESHOLD_MICRO=40
GRAMCREDIT_THRESHOLD_MINI=60
GRAMCREDIT_THRESHOLD_STANDARD=75
GRAMCREDIT_MIN_CONFIDENCE=0.75
GRAMCREDIT_MIN_AGE=21
GRAMCREDIT_MAX_AGE=65
GRAMCREDIT_MIN_PAST_LOANS=0

# ==============================
# Logging
# ==============================
GRAMCREDIT_ENABLE_TRACES=true
GRAMCREDIT_PERSIST_TRACES=false
GRAMCREDIT_DB_URL=
GRAMCREDIT_LOG_LEVEL=info
